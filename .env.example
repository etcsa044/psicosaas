# ============================================
# PsicoSaaS — Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/psicosaas_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_to_a_strong_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_to_another_strong_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Encryption (AES-256)
ENCRYPTION_KEY=change_me_to_a_64_char_hex_string_for_aes256

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# S3 / MinIO
S3_ENDPOINT=
S3_BUCKET=psicosaas-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
